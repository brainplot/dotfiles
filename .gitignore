# Ignore anything except for dotfiles, LICENSE and README.md
/[^.]*
!/LICENSE
!/README.md

# Ignore anything but ~/.ssh/config
/.ssh/*
!/.ssh/config

# Zsh
/.zcomp*
/.zsh_sessions/
/.local/share/zsh/plugins/

# Completion scripts
_*

# Ignore .password-store since it's its own repo
/.password-store/

# Ignore misc src folder
/.local/share/src/

# Ignore local CA folder
/.local/share/ssl/

# History files
.*_history

# WSL artifacts
/.hushlogin
/.motd_shown
/.sudo_as_admin_successful

# Vim
/.vim
/.viminfo
/.vimrc

# Ignore ~/.git-prompt.sh and ~/.git-completion.bash symlinks
/.git-prompt.sh
/.git-completion.bash

# Cloud platforms config data (created by Docker for Windows)
/.aws
/.azure

# Docker
/.docker/

# Claude
/.claude.json
/.claude/
/.local/share/claude/

# CUPS
/.cups/

# Misc
/.wget-hsts
/.nvimlog
/.Xauthority
/.gtkrc-2.0
/.fonts.conf

# Ignore cache directory
/.cache

# Ignore Kubernetes data
/.kube

# Ignore dotfiles Git repo
/.dotfiles.git

# GNUPG
/.gnupg/*
!/.gnupg/gpg-agent.conf

# GitHub CLI
/.config/gh/*
!/.config/gh/config.yaml

# Ignore user binaries
/.local/bin/

# Ignored config
!/.local/share/cargo/config.toml
/.anyconnect
/.bundle/
/.cisco/
/.config/Code/
/.config/github-copilot/
/.config/helm/
/.config/htop/
/.config/iterm2/
/.config/nvim/
/.config/packer/
/.config/wireshark/
/.config/zed/
/.gem/
/.local/pipx/
/.local/sessionmanagerplugin/
/.local/share/cargo/*
/.local/share/containers/
/.local/share/direnv/
/.local/share/fzf/
/.local/share/gem/
/.local/share/go/
/.local/share/mkcert/
/.local/share/node_modules/
/.local/share/nvim/
/.local/share/pyenv/
/.local/share/rustup/
/.local/share/tmux/
/.terraform.d/

# State folder
/.local/state/

# Powerlevel10k config
/.p10k.zsh

# HashiCorp Vault token
/.vault-token

# zsh-z
/.z

# irssi folder
/.irssi/

# VSCode folder
/.vscode/

# Virus Total CLI
/.vt.relationships.cache
/.vt.toml

# Gradle
/.local/share/gradle/
/.gradle/

# Maven
/.m2/

# LLDB
/.lldb/

# WireGuard
/.vpn/

# MacOS
/.CFUserTextEncoding
/.Trash/

# Terminfo database
/.terminfo/

# VNC Client
/.vnc/

# AWS SAM CLI
/.aws-sam/

# KDE / Plasma / Qt
# QtProject* covers both QtProject.conf and QtProject/
.config/QtProject*
.config/Trolltech.conf
# KDE/ (uppercase) is distinct from kde* on a case-sensitive filesystem
.config/KDE/
# kde* covers kdeglobals, kded5rc, kdeconnect/, kdedefaults/, kde.org/
.config/kde*
# k*rc covers the large family of k-prefixed rc files
.config/k*rc
.config/konsolesshconfig
.config/krecentconnections
.config/kwinoutputconfig.json
# plasma* covers plasma-nm, plasmarc, plasmashellrc, plasma-org.kde.*, etc.
.config/plasma*
.config/baloofileinformationrc
.config/bluedevilglobalrc
.config/breezerc
.config/dolphinrc
.config/filetypesrc
.config/gwenviewrc
.config/haruna/
.config/menus/
# power* covers powerdevilrc and powermanagementprofilesrc
.config/power*
.config/spectaclerc
.config/systemmonitorrc
.config/trashrc
.local/share/gwenview/
.local/share/haruna/
.local/share/kactivitymanagerd/
.local/share/klipper/
.local/share/konsole/
.local/share/krunnerstaterc
.local/share/kwalletd/
.local/share/plasma-systemmonitor/
.local/share/qtposition-geoclue2
.local/share/sddm/
# user-places.xbel* covers the file, .bak, and .tbcache
.local/share/user-places.xbel*

# GTK / GNOME
# gtk* covers gtk-3.0/, gtk-4.0/, gtkrc, and gtkrc-2.0
.config/gtk*
.config/dconf/
.config/xsettingsd/

# Fonts
.config/fontconfig/
.local/share/fonts/

# Go development
.config/go/
.config/dlv/

# Browsers & email
.mozilla/
.thunderbird/

# Media & entertainment
.config/mpv/input.conf
.config/mpv/script-opts/
.config/mpv/scripts/
.config/mpv/shaders/
.config/spotify/
.local/share/spotify-launcher/
.local/share/TelegramDesktop/

# System & XDG infrastructure
.config/libaccounts-glib/
.config/mimeapps.list
.config/pulse/
.config/session/
.config/speech-dispatcher/
.config/systemd/
.config/user-dirs.dirs
.config/user-dirs.locale
.config/xdg-desktop-portal/
.local/share/applications/
.local/share/flatpak/
.local/share/recently-used.xbel
.local/share/Trash/

# Applications
.config/keepassxc/
.config/qBittorrent/
.local/share/qBittorrent/
.config/uhk-agent/
.config/vim/
.config/Zeal/
.local/share/zeal/
.local/share/zed/

# Networking & DevOps
.config/dagger/
.local/share/dagger/
.local/share/MikroTik/
.mitmproxy/
.talos/

# Security & private data
.pki/
.private/
